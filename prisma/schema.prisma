generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String            @id @default(cuid())
  username         String            @unique
  passwordHash     String
  role             String            @default("user")
  passwordExpireAt DateTime
  isActive         Boolean           @default(true)
  examType         String            @default("guo_kao")
  targetProvince   String?
  targetScore      Int               @default(85)
  examDate         DateTime?
  dailyGoal        Int               @default(70)
  onboardingCompletedAt DateTime?
  createdAt        DateTime          @default(now())
  importJobs       ImportJob[]
  mockTests        MockTestRecord[]
  paperPracticeSessions PaperPracticeSession[]
  userErrors       UserError[]
  insights         UserInsight[]
  notes            UserNote[]
  knowledgeNodes   KnowledgeNode[]
  noteAssets       NoteAsset[]
  sectionStats     UserSectionStats?

  @@map("users")
}

model Question {
  id                   String           @id @default(cuid())
  addedBy              String
  content              String
  questionImage        String?
  options              String?
  answer               String
  analysis             String?
  type                 String
  subtype              String?
  sub2                 String?
  skillTags            String?
  examType             String           @default("common")
  srcProvince          String?
  srcExamSession       String?
  srcYear              String?
  srcOrigin            String?
  srcQuestionNo        String?
  srcQuestionOrder     Int?
  isFromOfficialBank   Boolean          @default(false)
  difficulty           String?
  estimatedCorrectRate Float?
  isPublic             Boolean          @default(true)
  isVerified           Boolean          @default(false)
  verifyCount          Int              @default(0)
  sharedAiAnalysis     String?
  sharedMemoryAnchor   String?
  createdAt            DateTime         @default(now())
  practiceRecords      PracticeRecord[]
  userErrors           UserError[]

  @@map("questions")
}

model UserError {
  id                   String         @id @default(cuid())
  userId               String
  questionId           String
  myAnswer             String
  aiRootReason         String?
  aiErrorReason        String?
  aiThinking           String?
  aiNoteDraft          String?
  aiReasonTag          String?
  aiActionRule         String?
  aiAnalyzedAt         DateTime?
  customAiAnalysis     String?
  errorReason          String?
  rootReason           String?
  reasonTag            String?
  nextReviewAt         DateTime       @default(now())
  reviewInterval       Int            @default(1)
  masteryPercent       Int            @default(0)
  reviewCount          Int            @default(0)
  correctCount         Int            @default(0)
  lastReviewedAt       DateTime?
  masteryHistory       String         @default("[]")
  stabilityScore       Float          @default(0.0)
  decayRatePerDay      Float          @default(0.0)
  isHot                Boolean        @default(false)
  isLastSlowCorrect    Boolean        @default(false)
  isStockified         Boolean        @default(false)
  reboundAlert         Boolean        @default(false)
  personalMemoryAnchor String?
  skillProgress        String?
  skillReviewCount     String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  reviews              ReviewRecord[]
  question             Question       @relation(fields: [questionId], references: [id])
  user                 User           @relation(fields: [userId], references: [id])

  @@unique([userId, questionId])
  @@map("user_errors")
}

model ReviewRecord {
  id                 String    @id @default(cuid())
  userId             String
  userErrorId        String
  questionSource     String    @default("real")
  isCorrect          Boolean
  timeSpent          Int?
  isTimeout          Boolean   @default(false)
  isSlowCorrect      Boolean   @default(false)
  thinkingInputType  String?
  userThinkingText   String?
  userThinkingImage  String?
  isAutoSubmitted    Boolean   @default(false)
  thinkingVerdict    String?
  thinkingFeedback   String?
  thinkingVerifiedAt DateTime?
  resultMatrix       String?
  createdAt          DateTime  @default(now())
  userError          UserError @relation(fields: [userErrorId], references: [id])

  @@map("review_records")
}

model PracticeRecord {
  id           String    @id @default(cuid())
  userId       String
  questionId   String
  isCorrect    Boolean   @default(false)
  isPending    Boolean   @default(false)
  nextShowAt   DateTime?
  questionType String?
  createdAt    DateTime  @default(now())
  question     Question  @relation(fields: [questionId], references: [id])

  @@unique([userId, questionId])
  @@index([userId, isPending])
  @@map("practice_records")
}

model UserNote {
  id              String         @id @default(cuid())
  userId          String
  knowledgeNodeId String?
  type            String
  subtype         String?
  module2         String?
  module3         String?
  sourceErrorIds  String?
  title           String
  content         String
  isPrivate       Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id])
  knowledgeNode   KnowledgeNode? @relation(fields: [knowledgeNodeId], references: [id])
  assets          NoteAsset[]

  @@index([userId, knowledgeNodeId, updatedAt])
  @@map("user_notes")
}

model KnowledgeNode {
  id        String          @id @default(cuid())
  userId    String
  parentId  String?
  nodeType  String          @default("knowledge")
  title     String
  source    String          @default("manual")
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id])
  parent    KnowledgeNode?  @relation("KnowledgeNodeChildren", fields: [parentId], references: [id])
  children  KnowledgeNode[] @relation("KnowledgeNodeChildren")
  notes     UserNote[]

  @@index([userId, parentId, sortOrder])
  @@index([userId, nodeType])
  @@map("knowledge_nodes")
}

model NoteAsset {
  id        String    @id @default(cuid())
  noteId     String?
  userId    String
  altText   String?
  mimeType  String
  dataUrl   String
  createdAt DateTime  @default(now())
  note      UserNote? @relation(fields: [noteId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId, noteId, createdAt])
  @@map("note_assets")
}

model UserInsight {
  id             String   @id @default(cuid())
  userId         String
  skillTag       String
  insightType    String
  aiDraft        String
  finalContent   String
  sourceErrorIds String?
  timesApplied   Int      @default(0)
  aiGenCount     Int      @default(0)
  domainExamples String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])

  @@map("user_insights")
}

model UserSectionStats {
  id             String   @id @default(cuid())
  userId         String   @unique
  statsJson      String
  predictedScore Int      @default(0)
  targetScore    Int      @default(85)
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id])

  @@map("user_section_stats")
}

model MockTestRecord {
  id            String   @id @default(cuid())
  userId        String
  testDate      DateTime @default(now())
  sourceName    String
  examType      String   @default("guo_kao")
  totalScore    Int
  totalScoreMax Int      @default(100)
  scoreJson     String?
  daysToExam    Int?
  notes         String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])

  @@map("mock_test_records")
}

model ImportJob {
  id              String   @id @default(cuid())
  userId          String
  filename        String
  status          String   @default("processing")
  parsedQuestions String?
  importedCount   Int      @default(0)
  failReason      String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])

  @@map("import_jobs")
}

model PaperPracticeSession {
  id               String   @id @default(cuid())
  userId           String
  paperKey         String
  paperTitle       String?
  paperYear        String?
  paperProvince    String?
  paperExamType    String?
  totalQuestions   Int      @default(0)
  activitySessionId String
  currentIndex     Int      @default(0)
  step             String   @default("paper_intro")
  status           String   @default("active")
  answeredIndices  String   @default("[]")
  markedIndices    String   @default("[]")
  answersJson      String   @default("{}")
  startedAt        DateTime @default(now())
  lastAccessedAt   DateTime @default(now())
  completedAt      DateTime?
  user             User     @relation(fields: [userId], references: [id])

  @@index([userId, paperKey, status])
  @@index([userId, activitySessionId])
  @@map("paper_practice_sessions")
}

model ExamTopicStats {
  id            String   @id @default(cuid())
  examType      String
  srcProvince   String?
  skillTag      String
  sectionType   String
  totalCount    Int      @default(0)
  frequency     Float    @default(0.0)
  avgDifficulty Float    @default(0.5)
  lastExamYear  Int?
  updatedAt     DateTime @updatedAt

  @@unique([examType, srcProvince, skillTag])
  @@map("exam_topic_stats")
}

model KnowledgeEntry {
  id               String                 @id @default(cuid())
  userId           String
  isPublic         Boolean                @default(true)
  questionId       String?
  rawContent       String
  rawAnalysis      String
  questionType     String
  methodName       String
  applicableTypes  String
  triggerKeywords  String
  solutionSteps    String
  exampleSolution  String
  qualityScore     Float                  @default(0.0)
  contentEmbedding Unsupported("vector")?
  aiExtractedAt    DateTime?
  usageCount       Int                    @default(0)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@map("knowledge_entries")
}

model AnalysisQueue {
  id            String    @id @default(cuid())
  userId        String?
  triggeredBy   String    @default("import")
  targetType    String
  targetId      String
  targetMeta    String?
  priority      Float     @default(0.5)
  status        String    @default("pending")
  failReason    String?
  retryCount    Int       @default(0)
  resultId      String?
  resultSummary String?
  analyzedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, priority])
  @@index([targetType, targetId])
  @@map("analysis_queue")
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  eventType  String
  entityType String?
  entityId   String?
  payload    String
  sessionId  String?
  deviceHint String?
  hourOfDay  Int?
  createdAt  DateTime @default(now())

  @@index([userId, eventType, createdAt])
  @@index([eventType, createdAt])
  @@index([userId, createdAt])
  @@map("activity_logs")
}

model AnalysisSnapshot {
  id               String    @id @default(cuid())
  userId           String?
  analysisType     String
  triggerEvent     String?
  dataRangeFrom    DateTime?
  dataRangeTo      DateTime?
  inputSummary     String
  prevSnapshotId   String?
  findings         String
  recommendations  String
  confidenceScore  Float     @default(0.0)
  dataPointsUsed   Int       @default(0)
  wasActedUpon     Boolean   @default(false)
  validatedAt      DateTime?
  validationResult String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId, analysisType, createdAt])
  @@map("analysis_snapshots")
}

model SystemInsight {
  id               String    @id @default(cuid())
  userId           String?
  sourceSnapshotId String?
  insightCategory  String
  targetEntity     String
  targetValue      String?
  paramKey         String
  paramValueOld    String?
  paramValueNew    String
  status           String    @default("pending")
  appliedAt        DateTime?
  appliedBy        String?
  rejectionReason  String?
  effectMetric     String?
  effectBefore     Float?
  effectAfter      Float?
  effectMeasuredAt DateTime?
  confidence       Float     @default(0.0)
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId, status])
  @@index([insightCategory, status])
  @@map("system_insights")
}

model AIFeedbackLog {
  id            String   @id @default(cuid())
  userId        String?
  sourceType    String
  sourceId      String
  analysisType  String?
  feedbackType  String
  feedbackValue String?
  comment       String?
  createdBy     String?
  createdAt     DateTime @default(now())

  @@index([userId, sourceType, sourceId, createdAt])
  @@index([sourceType, sourceId, createdAt])
  @@index([userId, feedbackType, createdAt])
  @@map("ai_feedback_logs")
}

model AnalysisDiscussion {
  id              String   @id @default(cuid())
  userId          String
  snapshotId      String
  findingIndex    Int
  action          String
  comment         String?
  confidenceDelta Float    @default(0.0)
  aiResponse      String?
  createdAt       DateTime @default(now())

  @@index([snapshotId, findingIndex])
  @@map("analysis_discussions")
}
