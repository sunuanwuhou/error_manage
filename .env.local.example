# ============================================================
# 错题管理系统 · 环境变量配置
# 复制本文件为 .env.local，填入实际值
# ============================================================

# 本地 PostgreSQL 连接（方案B）
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/wrongquestion"

# NextAuth
NEXTAUTH_SECRET="your-random-secret-here"   # openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"         # Tunnel 上线后改为 tunnel 域名

# ============================================================
# AI 配置（优先级：Claude > MiniMax）
# 系统会自动检测哪个 Key 可用，优先使用 Claude
# ============================================================

# 【推荐】Claude API Key（Anthropic）
# 获取地址：https://console.anthropic.com → API Keys
# 注意：这是独立的 API 计费，与 claude.ai 包月订阅无关
# 价格参考：Sonnet 约 ¥0.02/千输入token，¥0.08/千输出token
# 充值最低 $5 即可使用
ANTHROPIC_API_KEY="sk-ant-api03-..."

# 【降级】MiniMax API Key（Claude 未配置时自动使用）
# 获取地址：https://platform.minimaxi.com
MINIMAX_API_KEY=""
MINIMAX_GROUP_ID=""

# 【可选】OpenAI API Key（用于知识库向量化，不配置则降级为关键词检索）
# 获取地址：https://platform.openai.com → API Keys
# 用途：text-embedding-3-small，约 ¥0.0001/千token（极便宜）
OPENAI_API_KEY=""

# ============================================================
# AI 模型选择说明
# ============================================================
# 配置了 ANTHROPIC_API_KEY：
#   → 所有 AI 功能使用 claude-sonnet-4-5
#   → 诊断质量最好，支持长文本，上下文理解强
#
# 只配置了 MINIMAX_API_KEY：
#   → 使用 abab6.5s-chat
#   → 成本更低，适合高频调用
#
# 两个都没配置：
#   → AI 功能不可用，但所有非AI功能正常工作
