FROM error_manage-app:latest

WORKDIR /workspace

RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 python3-pip python3-venv \
  && rm -rf /var/lib/apt/lists/*

RUN python3 -m venv /opt/ocr-venv

RUN /opt/ocr-venv/bin/pip install --upgrade pip

RUN /opt/ocr-venv/bin/pip install paddlepaddle paddleocr pillow

ENV PATH="/opt/ocr-venv/bin:${PATH}"

CMD ["python", "scripts/test-paddleocr-34.py"]
