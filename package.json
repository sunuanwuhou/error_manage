{
  "name": "wrongquestion",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:restart": "zsh scripts/restart-dev.sh",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "smoke:backend": "npm run typecheck && npm run build && npm run test:import",
    "smoke:frontend": "npm run test:e2e",
    "smoke:all": "npm run smoke:backend && npm run smoke:frontend",
    "analysis:worker": "node analysis-worker/src/index.mjs",
    "analysis:seed:testdata": "node scripts/seed-ai-evolution-test-data.mjs",
    "analysis:claim": "node analysis-worker/src/index.mjs --claim-and-export",
    "analysis:dispatch": "node analysis-worker/src/index.mjs --enqueue-stale-strategy --claim-and-export",
    "analysis:autopilot": "node analysis-worker/src/index.mjs --autopilot",
    "analysis:export": "node analysis-worker/src/index.mjs",
    "analysis:latest": "node analysis-worker/src/index.mjs --show-latest",
    "analysis:apply": "node analysis-worker/src/index.mjs --apply-result",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:install": "playwright install chromium",
    "test:import": "node --test --experimental-strip-types src/lib/import/*.test.mjs",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.3.1",
    "mammoth": "^1.12.0",
    "next": "14.1.0",
    "next-auth": "^4.24.6",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "react": "^18",
    "react-dom": "^18",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.1.0",
    "postcss": "^8",
    "prisma": "^5.10.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
